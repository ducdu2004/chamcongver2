<Page x:Class="chamcong.WpfAdmin.Views.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Nhân viên">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Danh sách Nhân sự" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="1" Text="* Thâm niên được tính tự động dựa vào lần ký hợp đồng/đi làm gần nhất. Nếu nhân viên nghỉ rồi làm lại, thâm niên sẽ đếm lại từ đầu nhưng dữ liệu cũ vẫn được lưu trong hệ thống." TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray" Margin="0,0,0,20"/>

        <DataGrid x:Name="dgEmployees" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" RowHeight="35" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Số điện thoại" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Ngày BĐ làm (Gần nhất)" Binding="{Binding LatestStartDate, StringFormat=dd/MM/yyyy}" Width="150"/>
                <DataGridTextColumn Header="Thâm niên (Năm)" Binding="{Binding SeniorityYears}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
