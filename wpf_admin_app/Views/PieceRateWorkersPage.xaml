<Page x:Class="chamcong.WpfAdmin.Views.PieceRateWorkersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:chamcong.WpfAdmin.Views"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Công theo sản phẩm (Khoán thủ công)" Background="White" Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Column: Employee Selection -->
        <Border Grid.Column="0" BorderBrush="#BDC3C7" BorderThickness="0,0,1,0" Padding="15">
            <StackPanel>
                <TextBlock Text="CHỌN NHÂN VIÊN" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="txtSearchEmployee" Width="220" Height="30" Padding="5" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="Tìm" Width="80" Height="30" Background="#3498DB" Foreground="White" BorderThickness="0" Click="btnSearchEmployee_Click"/>
                </StackPanel>

                <DataGrid x:Name="dgEmployees" AutoGenerateColumns="False" IsReadOnly="True" Height="480" 
                          SelectionChanged="dgEmployees_SelectionChanged" SelectionMode="Single"
                          HeadersVisibility="Column" Background="White" RowBackground="White" AlternatingRowBackground="#F9F9F9">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Tên Nhân Viên" Binding="{Binding FullName}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Right Column: Piece Rate Entry & History -->
        <Border Grid.Column="1" Padding="20">
            <StackPanel>
                <TextBlock Text="GHI NHẬN CÔNG KHOÁN SẢN PHẨM" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                <TextBlock x:Name="txtSelectedEmployee" Text="Vui lòng chọn nhân viên bên trái..." FontSize="14" Foreground="#7F8C8D" Margin="0,0,0,20"/>

                <!-- Entry Form -->
                <Grid Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0: Product & Part -->
                    <TextBlock Text="Sản phẩm:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <ComboBox x:Name="cbProducts" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,15,10" DisplayMemberPath="ProductName" SelectedValuePath="Id" SelectionChanged="cbProducts_SelectionChanged"/>

                    <TextBlock Text="Bộ phận:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <ComboBox x:Name="cbGarmentParts" Grid.Row="0" Grid.Column="3" Height="30" Margin="0,0,0,10" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                    <!-- Row 1: Size/Table & Quantity -->
                    <TextBlock Text="Size / Bàn:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBox x:Name="txtSizeOrTable" Grid.Row="1" Grid.Column="1" Height="30" Margin="0,0,15,10" Padding="5"/>

                    <TextBlock Text="Số lượng:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBox x:Name="txtQuantity" Grid.Row="1" Grid.Column="3" Height="30" Margin="0,0,0,10" Padding="5"/>

                    <!-- Row 2: Unit Price & Button -->
                    <TextBlock Text="Đơn giá:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtUnitPrice" Grid.Row="2" Grid.Column="1" Height="30" Margin="0,0,15,0" Padding="5" IsReadOnly="True" Background="#F0F0F0" Foreground="#555"/>

                    <Button x:Name="btnSaveProduction" Grid.Row="2" Grid.Column="3" Content="Ghi Nhận" Height="30" Background="#2ECC71" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="btnSaveProduction_Click"/>
                </Grid>

                <Rectangle Height="1" Fill="#BDC3C7" Margin="0,10,0,15"/>

                <TextBlock Text="CÔNG ĐÃ GHI NHẬN HÔM NAY" FontSize="14" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,10"/>
                
                <DataGrid x:Name="dgProductionLogs" AutoGenerateColumns="False" IsReadOnly="True" Height="280"
                          HeadersVisibility="Column" Background="White" RowBackground="White" AlternatingRowBackground="#F9F9F9">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Thời gian" Binding="{Binding CompletedAt, StringFormat={}{0:HH:mm}}" Width="80"/>
                        <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Bộ phận" Binding="{Binding GarmentPartName}" Width="120"/>
                        <DataGridTextColumn Header="Size/Bàn" Binding="{Binding SizeOrTable}" Width="80"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="50"/>
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat={}{0:N0}}" Width="80"/>
                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding EarnedAmount, StringFormat={}{0:N0}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

            </StackPanel>
        </Border>

    </Grid>
</Page>
