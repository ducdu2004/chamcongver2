<Page x:Class="chamcong.WpfAdmin.Views.BatchesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Lô Hàng / Sản lượng">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,10">
            <TextBlock Text="Danh Sách Lô Hàng &amp; Sản Lượng" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Nhập Hàng" Background="#2ECC71" Foreground="White" BorderThickness="0" Padding="15,8" Margin="0,0,10,0" Click="btnAddBatch_Click"/>
                <Button Content="Chia Hàng" Background="#F1C40F" Foreground="Black" BorderThickness="0" Padding="15,8" Margin="0,0,10,0" Click="btnCreateSubBatch_Click"/>
                <Button Content="Phát sinh Bó Hàng" Background="#9B59B6" Foreground="White" BorderThickness="0" Padding="15,8" Click="btnGenerateBundles_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Danh Sách Lô Gốc (Xưởng Chính)" Grid.Row="0">
                <DataGrid x:Name="dgRootBatches" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" RowHeight="40" AlternatingRowBackground="#F9F9F9" SelectionMode="Single" SelectionChanged="dgBatches_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID Lô" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding ProductName}" Width="250"/>
                        <DataGridTextColumn Header="Số Lượng" Binding="{Binding Quantity}" Width="100"/>
                        <DataGridTextColumn Header="Ngày Nhập" Binding="{Binding ReceiveDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Người Nhập" Binding="{Binding ReceiverName}" Width="120"/>
                        <DataGridTextColumn Header="Đơn Giá" Binding="{Binding UnitPrice, StringFormat=N0}" Width="100"/>
                        <DataGridTextColumn Header="Xưởng/Thầu phụ" Binding="{Binding AssignedWorkshopName}" Width="150"/>
                        <DataGridTextColumn Header="Trạng Thái" Binding="{Binding StatusText}" Width="120"/>
                        
                        <DataGridTemplateColumn Header="Nhân Sự Tham Gia" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xem danh sách" Background="#3498DB" Foreground="White" BorderThickness="0" Padding="10,5" Click="btnViewEmployees_Click" CommandParameter="{Binding Id}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <GroupBox Header="Danh Sách Lô Con (Giao Thầu Phụ)" Grid.Row="2">
                <DataGrid x:Name="dgSubBatches" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" RowHeight="40" AlternatingRowBackground="#F9F9F9" SelectionMode="Single" SelectionChanged="dgBatches_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID Lô" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="ID Lô Cha" Binding="{Binding ParentBatchId}" Width="80"/>
                        <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding ProductName}" Width="250"/>
                        <DataGridTextColumn Header="Số Lượng" Binding="{Binding Quantity}" Width="100"/>
                        <DataGridTextColumn Header="Đơn Giá" Binding="{Binding UnitPrice, StringFormat=N0}" Width="100"/>
                        <DataGridTextColumn Header="Xưởng/Thầu phụ" Binding="{Binding AssignedWorkshopName}" Width="150"/>
                        <DataGridTextColumn Header="Trạng Thái" Binding="{Binding StatusText}" Width="120"/>
                        
                        <DataGridTemplateColumn Header="Nhân Sự Tham Gia" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xem danh sách" Background="#3498DB" Foreground="White" BorderThickness="0" Padding="10,5" Click="btnViewEmployees_Click" CommandParameter="{Binding Id}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</Page>
