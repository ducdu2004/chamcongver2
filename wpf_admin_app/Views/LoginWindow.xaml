<Window x:Class="chamcong.WpfAdmin.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Login" Height="300" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Đăng nhập Hệ thống" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <TextBlock Text="Tên đăng nhập:"/>
            <TextBox x:Name="txtUsername" Margin="0,5,0,15" Padding="5"/>
            
            <TextBlock Text="Mật khẩu:"/>
            <PasswordBox x:Name="txtPassword" Margin="0,5,0,20" Padding="5"/>
            
            <Button x:Name="btnLogin" Content="ĐĂNG NHẬP" Height="35" Background="#2196F3" Foreground="White" FontWeight="Bold" Click="btnLogin_Click"/>
            
            <TextBlock x:Name="txtError" Foreground="Red" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
