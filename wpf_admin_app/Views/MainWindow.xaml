<Window x:Class="chamcong.WpfAdmin.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:chamcong.WpfAdmin"
        mc:Ignorable="d"
        Title="Hệ Thống Quản Lý Xưởng May (Admin)" Height="600" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="ADMIN DASHBOARD" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                
                <Button x:Name="btnDistributors" Content="Nhà phân phối" Height="40" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0" Click="btnDistributors_Click"/>
                <Button x:Name="btnProductCategories" Content="Cấu hình Bộ phận SP" Height="40" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0" Click="btnProductCategories_Click"/>
                <Button x:Name="btnProducts" Content="Sản phẩm &amp; Định mức" Height="40" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0" Click="btnProducts_Click"/>
                <Button x:Name="btnBatches" Content="Quản lý Lô Hàng / Sản lượng" Height="40" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0" Click="btnBatches_Click"/>
                <Button x:Name="btnEmployees" Content="Nhân viên" Height="40" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0" Click="btnEmployees_Click"/>
                <Button x:Name="btnDailyWorkers" Content="Công nhật / Chấm công" Height="40" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0" Click="btnDailyWorkers_Click"/>
                <Button x:Name="btnPieceRateWorkers" Content="Công theo sản phẩm" Height="40" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0" Click="btnPieceRateWorkers_Click"/>
                <Button x:Name="btnIssues" Content="Xử lý Khiếu nại" Height="40" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0" Click="btnIssues_Click"/>
                
                <Rectangle Height="1" Fill="#34495E" Margin="10,15"/>
                
                <Button x:Name="btnLogout" Content="Đăng xuất" Height="40" Margin="10,5" Background="#E74C3C" Foreground="White" BorderThickness="0" Click="btnLogout_Click"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#ECF0F1"/>
    </Grid>
</Window>
