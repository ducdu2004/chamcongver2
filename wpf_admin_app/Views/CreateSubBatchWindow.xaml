<Window x:Class="chamcong.WpfAdmin.Views.CreateSubBatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo Lô Con (Giao Thầu phụ)" Height="350" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="lblBatchInfo" Grid.Row="0" FontWeight="Bold" Margin="0,0,0,15"/>

        <TextBlock Text="Số lượng cắt ra:" Grid.Row="1" Margin="0,0,0,5"/>
        <TextBox x:Name="txtQuantity" Grid.Row="2" Height="30" Margin="0,0,0,15"/>

        <TextBlock Text="Đơn giá / Sản phẩm:" Grid.Row="3" Margin="0,0,0,5"/>
        <TextBox x:Name="txtUnitPrice" Grid.Row="4" Height="30" Margin="0,0,0,15"/>

        <TextBlock Text="Xưởng nhận / Thầu phụ:" Grid.Row="5" Margin="0,0,0,5"/>
        <ComboBox x:Name="cbWorkshops" Grid.Row="6" DisplayMemberPath="Name" SelectedValuePath="Id" Height="30" VerticalAlignment="Top"/>

        <Button x:Name="btnSave" Grid.Row="7" Content="Tạo Lô Con" Height="35" Width="100" Background="#F1C40F" Foreground="Black" BorderThickness="0" HorizontalAlignment="Right" Click="btnSave_Click"/>
    </Grid>
</Window>
