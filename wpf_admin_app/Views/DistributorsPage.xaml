<Page x:Class="chamcong.WpfAdmin.Views.DistributorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Nhà phân phối" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Danh sách Nhà phân phối" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtSearch" Width="250" Height="30" VerticalContentAlignment="Center" Padding="5,0" Tag="Tìm kiếm theo Tên, SĐT..."/>
                <Button Content="Tìm kiếm" Width="80" Height="30" Margin="10,0,0,0" Click="btnSearch_Click"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Thêm Nhà phân phối" Background="#2ECC71" Foreground="White" BorderThickness="0" Padding="15,5" Height="35" Click="btnAddDistributor_Click"/>
        </Grid>

        <DataGrid x:Name="dgDistributors" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" 
                  Background="White" RowHeight="35" ColumnHeaderHeight="40" BorderBrush="#E0E0E0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên Nhà phân phối" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Số điện thoại" Binding="{Binding Phone}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Địa chỉ" Binding="{Binding Address}" Width="2*"/>
                <DataGridTemplateColumn Header="Thao tác" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Sửa" Margin="0,0,5,0" Background="#3498DB" Foreground="White" BorderThickness="0" Padding="5,2" Click="btnEdit_Click"/>
                                <Button Content="Xóa" Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="5,2" Click="btnDelete_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
