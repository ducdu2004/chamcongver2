<Page x:Class="chamcong.WpfAdmin.Views.ProductCategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Danh mục &amp; Bộ phận">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Cấu hình Danh mục &amp; Bộ phận Sản phẩm" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Product Categories -->
            <GroupBox Header="Danh mục Sản phẩm (Áo, Quần...)" Grid.Column="0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="txtCategoryName" Width="200" Height="30" Margin="0,0,10,0"/>
                        <Button x:Name="btnAddCategory" Content="Thêm mới" Width="80" Background="#2ECC71" Foreground="White" BorderThickness="0" Click="btnAddCategory_Click"/>
                    </StackPanel>
                    
                    <DataGrid x:Name="dgCategories" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="dgCategories_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Tên Danh mục" Binding="{Binding Name}" Width="*"/>
                            <DataGridTemplateColumn Header="" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Sửa" Background="#F39C12" Foreground="White" BorderThickness="0" Padding="5,2" Margin="0,0,5,0" Click="btnEditCategory_Click"/>
                                            <Button Content="Xóa" Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="5,2" Click="btnDeleteCategory_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <!-- Garment Parts -->
            <GroupBox x:Name="grpParts" Header="Bộ phận thuộc Danh mục" Grid.Column="2" Padding="10" IsEnabled="False">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Tên bộ phận:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtPartName" Width="120" Height="30" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                        
                        <TextBlock Text="Đơn giá (VNĐ):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtPartUnitPrice" Width="100" Height="30" Margin="0,0,10,0" Text="0" VerticalContentAlignment="Center"/>
                        
                        <Button x:Name="btnAddPart" Content="Thêm Bộ phận" Width="100" Background="#3498DB" Foreground="White" BorderThickness="0" Click="btnAddPart_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgParts" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Tên Bộ phận (Thân, Cổ...)" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Đơn giá / 1 chiếc" Binding="{Binding DefaultUnitPrice, StringFormat={}{0:N0}}" Width="120"/>
                            <DataGridTemplateColumn Header="Hành động" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Sửa" Background="#F39C12" Foreground="White" BorderThickness="0" Padding="5,2" Margin="0,0,5,0" Click="btnEditPart_Click"/>
                                            <Button Content="Xóa" Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="5,2" Click="btnDeletePart_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Page>
