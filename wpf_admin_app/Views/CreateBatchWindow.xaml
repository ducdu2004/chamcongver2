<Window x:Class="chamcong.WpfAdmin.Views.CreateBatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập Hàng (Lô Gốc)" Height="380" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Nhà phân phối:" Grid.Row="0" Margin="0,0,0,5"/>
        <ComboBox x:Name="cbDistributors" Grid.Row="1" DisplayMemberPath="Name" SelectedValuePath="Id" Height="30" Margin="0,0,0,15" SelectionChanged="cbDistributors_SelectionChanged"/>

        <TextBlock Text="Sản phẩm:" Grid.Row="2" Margin="0,0,0,5"/>
        <ComboBox x:Name="cbProducts" Grid.Row="3" DisplayMemberPath="ProductName" SelectedValuePath="Id" Height="30" Margin="0,0,0,15"/>

        <TextBlock Text="Số lượng nhập về:" Grid.Row="4" Margin="0,0,0,5"/>
        <TextBox x:Name="txtQuantity" Grid.Row="5" Height="30" Margin="0,0,0,15"/>

        <TextBlock x:Name="lblInfo" Text="Ngày nhập: ... | Người nhập: ..." Grid.Row="6" Margin="0,0,0,15" Foreground="Gray" FontStyle="Italic"/>

        <Button x:Name="btnSave" Grid.Row="8" Content="Lưu" Height="35" Width="100" Background="#3498DB" Foreground="White" BorderThickness="0" HorizontalAlignment="Right" Click="btnSave_Click"/>


    </Grid>
</Window>
