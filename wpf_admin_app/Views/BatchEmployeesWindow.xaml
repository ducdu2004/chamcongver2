<Window x:Class="chamcong.WpfAdmin.Views.BatchEmployeesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thống kê Nhân sự làm lô hàng" Height="450" Width="600" WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Danh Sách Nhân Sự Đã Gia Công Lô Hàng" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <DataGrid x:Name="dgBatchEmployees" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" RowHeight="35" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã NV" Binding="{Binding EmployeeId}" Width="80"/>
                <DataGridTextColumn Header="Họ và Tên" Binding="{Binding EmployeeName}" Width="200"/>
                <DataGridTextColumn Header="Số bó hoàn thành" Binding="{Binding TotalBundles}" Width="150"/>
                <DataGridTextColumn Header="Tổng tiền nhận (VNĐ)" Binding="{Binding TotalEarned, StringFormat=N0}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
