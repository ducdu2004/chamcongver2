<Page x:Class="chamcong.WpfAdmin.Views.DailyWorkersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Công nhật">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Quản lý Công nhật &amp; Chấm công" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <DataGrid x:Name="dgDailyWorkers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" RowHeight="40" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Lương 1H (VNĐ)" Binding="{Binding HourlyWage, StringFormat=N0}" Width="150"/>
                <DataGridTextColumn Header="Lương Tăng ca 1H (VNĐ)" Binding="{Binding OvertimeHourlyWage, StringFormat=N0}" Width="150"/>
                <DataGridTextColumn Header="Tổng giờ tăng ca" Binding="{Binding TotalOvertimeHours}" Width="120"/>
                
                <DataGridTemplateColumn Header="Hành động" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Bảng chấm công" Background="#27AE60" Foreground="White" BorderThickness="0" Padding="10,5" Click="btnViewAttendance_Click" CommandParameter="{Binding Id}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
